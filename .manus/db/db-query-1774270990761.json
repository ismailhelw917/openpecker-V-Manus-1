  "query": "\n-- Check openings and puzzle counts\nSELECT \n  o.name AS openingName,\n  o.ecoCode,\n  o.isPremium AS isLocked,\n  COUNT(p.id) AS puzzleCount\nFROM openings o\nLEFT JOIN puzzles p ON p.openingName = o.name OR p.opening = o.name\nGROUP BY o.id, o.name, o.ecoCode, o.isPremium\nORDER BY o.isPremium ASC, puzzleCount DESC;\n",
